{
  "name": "mikrotik-network-controller",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "^7.0.0-dev.20260419.1",
    "drizzle-kit": "^0.31.10",
    "sass": "^1.99.0",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@sourceregistry/mikrotik-client": "^1.0.0-alpha.3",
    "@sourceregistry/node-env": "^1.6.2",
    "@sourceregistry/node-validator": "^1.1.5",
    "@sourceregistry/sveltekit-websockets": "^1.0.6",
    "@sourceregistry/sveltekit-service-manager": "^1.3.0",
    "@xyflow/svelte": "^1.5.2",
    "bootstrap-icons": "^1.13.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
